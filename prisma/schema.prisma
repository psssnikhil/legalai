// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  department    String?
  phone         String?
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  cases    Case[]
  chatSessions ChatSession[]
  documents Document[]
  voiceNotes VoiceNote[]
  hearings Hearing[]
  clients  Client[]
  settings UserSettings?
  caseNotes CaseNote[]
}

model UserSettings {
  id        String   @id @default(cuid())
  
  // Feature Flags
  ragEnabled Boolean  @default(false)  // Enable RAG for document retrieval in chat
  
  // Future settings can be added here
  // aiProvider String?  @default("openai")
  // maxTokens  Int?     @default(1000)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Case {
  id           String   @id @default(cuid())
  title        String
  description  String?
  status       String   @default("ACTIVE") // ACTIVE, PENDING, REVIEW, CLOSED, URGENT
  priority     String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  caseType     String?  // Employment, Civil Litigation, Corporate Law, etc.
  caseValue    Float?   // Monetary value of the case
  clientName   String?
  clientEmail  String?
  clientPhone  String?
  clientId     String?
  client       Client?  @relation("ClientCases", fields: [clientId], references: [id])
  assignedTo   String?  // Lawyer/team member assigned
  nextHearing  DateTime?
  lastUpdated  DateTime @updatedAt
  startDate    DateTime @default(now())
  endDate      DateTime?
  isDraft      Boolean  @default(false)
  googleDriveFolderId  String?
  googleDriveFolderUrl String?
  openaiVectorStoreId  String?
  tags         String?

  // Opposite party info
  oppositeParty   String?
  oppositeCounsel String?
  courtFileNumber String?
  firNumber       String?

  // Deadlines
  limitationDate  DateTime?
  filingDeadline  DateTime?
  replyDeadline   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  chatSessions ChatSession[]
  documents    Document[]
  analyses     CaseAnalysis[]
  hearings     Hearing[]
  tasks        Task[]
  notes        CaseNote[]
}

model ChatSession {
  id        String   @id @default(cuid())
  title     String?
  openaiThreadId String?  // OpenAI Assistants API thread ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id])
  userId String
  user   User    @relation(fields: [userId], references: [id])

  messages ChatMessage[]
  voiceNotes VoiceNote[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  role      String   // 'user' or 'assistant'
  createdAt DateTime @default(now())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  attachments Document[]
}

model Document {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  content     String?  // Extracted text content
  binaryData  Bytes?   // Raw file binary data (for PDFs, images, etc.)
  s3Key       String?  // S3 key if stored in S3
  s3Url       String?  // S3 URL if stored in S3
  openaiFileId        String? // OpenAI Files API file ID
  googleDriveFileId   String? // Google Drive file ID
  googleDriveFileUrl  String? // Google Drive shareable link
  analysis    String?  // AI analysis results
  createdAt   DateTime @default(now())

  caseId    String?
  case      Case?        @relation(fields: [caseId], references: [id])
  clientId  String?
  client    Client?      @relation("ClientDocuments", fields: [clientId], references: [id])
  messageId String?
  message   ChatMessage? @relation(fields: [messageId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
}

model VoiceNote {
  id          String   @id @default(cuid())
  filename    String
  transcription String?
  duration    Int?     // in seconds
  createdAt   DateTime @default(now())

  sessionId String?
  session   ChatSession? @relation(fields: [sessionId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
}

model CaseAnalysis {
  id                String   @id @default(cuid())
  parties           String?  // JSON string of parties
  caseType          String?
  jurisdiction      String?
  winningProbability Float?
  keyFacts          String?  // JSON string of key facts
  evidence          String?  // JSON string of evidence
  actionItems       String?  // JSON string of action items
  confidence        Float?   // Overall confidence score
  createdAt         DateTime @default(now())

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id])
}

model Hearing {
  id           String   @id @default(cuid())
  title        String
  hearingDate  DateTime
  startTime    String   // Format: "HH:MM"
  endTime      String?  // Format: "HH:MM"
  duration     Int      @default(60) // Duration in minutes
  
  // Case and Client Information
  caseId       String?
  case         Case?    @relation(fields: [caseId], references: [id])
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  clientName   String?
  
  // Location Details
  state        String?
  district     String?
  court        String?
  courtType    String?  // Supreme Court, High Court, District Court, etc.
  courtRoom    String?
  
  // Judge and Priority
  judgeName    String?
  priority     String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  
  // Status and Type
  status       String   @default("SCHEDULED") // SCHEDULED, COMPLETED, RESCHEDULED, CANCELLED
  hearingType  String?  // Motion Hearing, Final Arguments, Case Conference, etc.
  
  // Additional Details
  notes        String?
  reminders    String?

  // Google Calendar
  googleCalendarEventId String?

  // Metadata
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  @@index([hearingDate])
  @@index([userId])
  @@index([caseId])
  @@index([status])
}

model Client {
  id              String   @id @default(cuid())
  
  // Basic Information
  name            String
  email           String
  phone           String
  
  // Optional Basic Fields
  company         String?
  address         String?
  
  // Type and Status
  clientType      String   @default("INDIVIDUAL") // INDIVIDUAL, COMPANY, ORGANIZATION
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  
  // Custom Fields (stored as JSON)
  customFields    String?  // JSON object for additional custom fields
  
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  cases           Case[]   @relation("ClientCases")
  documents       Document[] @relation("ClientDocuments")
  hearings        Hearing[]
  
  @@index([userId])
  @@index([status])
  @@index([email])
}

model Task {
  id        String    @id @default(cuid())
  title     String
  done      Boolean   @default(false)
  dueDate   DateTime?
  caseId    String
  case      Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([caseId])
}

model CaseNote {
  id        String   @id @default(cuid())
  content   String
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([caseId])
}
