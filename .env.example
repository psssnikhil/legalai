# =========================================
# REQUIRED
# =========================================

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# For local dev only:
# DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI
OPENAI_API_KEY="sk-proj-..."
OPENAI_ASSISTANT_ID=""   # auto-generated on first run, then paste here

# =========================================
# GOOGLE OAUTH (for sign-in)
# =========================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =========================================
# GOOGLE DRIVE SERVICE ACCOUNT (for file storage)
# Setup: console.cloud.google.com → IAM → Service Accounts → Create → Download JSON key
# Then share your company Drive folder with the service account email
# =========================================
GOOGLE_SERVICE_ACCOUNT_EMAIL="legal-ai-drive@your-project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GOOGLE_DRIVE_PARENT_FOLDER_ID=""  # The ID from your company Drive folder URL
